        {
          "name": "GET — Fan zones à proximité rayon 500m (PUBLIC)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Réponse est un tableau', () => {",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "});",
                  "const zones = pm.response.json();",
                  "if (zones.length > 1) {",
                  "    pm.test('Triées par distance croissante', () => {",
                  "        for (let i = 0; i < zones.length - 1; i++) {",
                  "            pm.expect(zones[i].distance).to.be.at.most(zones[i+1].distance);",
                  "        }",
                  "    });",
                  "}",
                  "zones.forEach(z => {",
                  "    pm.test('Zone dans le rayon (distance <= 500m)', () => {",
                  "        pm.expect(z.distance).to.be.at.most(500);",
                  "    });",
                  "});"
                ],
                "type": "text/javascript"
              }
