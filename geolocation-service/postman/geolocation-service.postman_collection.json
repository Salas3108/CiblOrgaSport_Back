    {
      "name": "⚙️ Admin — Configuration Athlète",
      "item": [
        {
          "name": "Activer géoloc pour athlète (+ définir nom)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "console.log('Géolocalisation activée pour athleteId=' + pm.collectionVariables.get('athleteId'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{adminToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"geolocActive\": true,\n  \"nom\": \"Léon Dupont\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/geo/admin/athletes/{{athleteId}}/config",
              "host": ["{{baseUrl}}"],
              "path": ["api", "geo", "admin", "athletes", "{{athleteId}}", "config"]
            }
          }
        },
        {
          "name": "Désactiver géoloc pour athlète",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
