          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"commissaire1\",\n  \"password\": \"commis123\"\n}"
            },
            "url": {"raw": "{{authUrl}}/auth/login", "host": ["{{authUrl}}"], "path": ["auth", "login"]}
          }
        }
      ]
