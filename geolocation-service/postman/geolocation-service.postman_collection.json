                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{adminToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"geolocActive\": false,\n  \"nom\": \"Léon Dupont\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/geo/admin/athletes/{{athleteId}}/config",
              "host": ["{{baseUrl}}"],
              "path": ["api", "geo", "admin", "athletes", "{{athleteId}}", "config"]
            }
          }
        },
        {
