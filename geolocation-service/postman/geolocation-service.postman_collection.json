          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{commissaireToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"geolocActive\": true,\n  \"nom\": \"Test\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/geo/admin/athletes/{{athleteId}}/config",
              "host": ["{{baseUrl}}"],
              "path": ["api", "geo", "admin", "athletes", "{{athleteId}}", "config"]
            }
          }
        }
      ]
    },
