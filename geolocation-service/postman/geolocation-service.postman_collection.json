{
  "info": {
    "name": "Geolocation Service — CiblOrgaSport",
    "description": "Collection complète pour tester le microservice de géolocalisation (port 8091).\n\nFlux de test recommandé :\n1. Auth > Login Admin → token sauvegardé automatiquement\n2. Admin Config > Activer géoloc pour athlète\n3. Auth > Login Athlete → token sauvegardé automatiquement\n4. Athlete > Enregistrer position\n5. Commissaire > Lire position / épreuve / historique\n6. Fan Zones > CRUD + recherche proximité",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8091",
      "type": "string"
    },
    {
      "key": "authUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "athleteToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "commissaireToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "athleteId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "epreuveId",
      "value": "45",
      "type": "string"
    },
    {
      "key": "fanzoneId",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔐 Auth (login pour récupérer les tokens)",
      "item": [
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('adminToken', json.token);",
                  "    console.log('Admin token sauvegardé');",
                  "}",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Token présent', () => pm.expect(pm.response.json()).to.have.property('token'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {"raw": "{{authUrl}}/auth/login", "host": ["{{authUrl}}"], "path": ["auth", "login"]}
          }
        },
        {
          "name": "Login Athlete (userId=1)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('athleteToken', json.token);",
                  "    console.log('Athlete token sauvegardé');",
                  "}",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"leon.dupont\",\n  \"password\": \"athlete123\"\n}"
            },
            "url": {"raw": "{{authUrl}}/auth/login", "host": ["{{authUrl}}"], "path": ["auth", "login"]}
          }
        },
        {
          "name": "Login Commissaire",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('commissaireToken', json.token);",
