{
  "info": {
    "name": "Resultat Service API",
    "description": "Collection pour tester l'API de gestion des résultats",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Créer un résultat",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          },
          {
            "key": "X-User-Id",
            "value": "{{userId}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"epreuveId\": 1,\n  \"athleteId\": 5,\n  \"classement\": 1,\n  \"temps\": 45.32,\n  \"distance\": 100.50,\n  \"points\": 100,\n  \"observations\": \"Athlète en excellente forme\"\n}"
        },
        "url": {
          "raw": "http://localhost:8085/api/resultats",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8085",
          "path": [
            "api",
            "resultats"
          ]
        }
      }
    },
    {
