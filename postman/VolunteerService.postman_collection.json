    {
      "name": "Volunteer - Complete Profile",
      "id": "c48c6522-1c2f-4b42-9c01-0b35e87e2bb4",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"phoneNumber\": \"+33612345678\",\n  \"languages\": [\"Français\", \"Anglais\"],\n  \"preferredTaskTypes\": [\"ACCUEIL\", \"ORIENTATION\"],\n  \"availabilities\": [\n    {\n      \"dayOfWeek\": \"MONDAY\",\n      \"startTime\": \"09:00\",\n      \"endTime\": \"12:00\"\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{volunteer_base}}/api/v1/volunteers/profile/complete",
          "host": [
            "{{volunteer_base}}"
          ],
          "path": [
            "api",
            "v1",
            "volunteers",
            "profile",
            "complete"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status is 201\", function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "const data = pm.response.json();",
              "pm.test(\"Response contains profile fields\", function () {",
              "  pm.expect(data.firstName).to.exist;",
              "  pm.expect(data.lastName).to.exist;",
              "  pm.expect(data.email).to.exist;",
              "});",
              "",
              "pm.test(\"Volunteer id is returned\", function () {",
              "  pm.expect(data.id).to.exist;",
              "});",
              "",
              "pm.environment.set('volunteer_id', data.id);",
              "",
              "pm.test(\"Profile is marked as complete\", function () {",
              "  pm.expect(data.profileComplete).to.eql(true);",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
