          "raw": "[\n  {\n    \"title\": \"Accueil Participants\",\n    \"description\": \"Accueil des participants à l'arrivée\",\n    \"taskDate\": \"2026-03-15\",\n    \"startTime\": \"09:00:00\",\n    \"endTime\": \"12:00:00\",\n    \"location\": \"Entrée Site A\",\n    \"taskType\": \"ACCUEIL\",\n    \"requiredLanguages\": [\"Français\"]\n  },\n  {\n    \"title\": \"Support Logistique\",\n    \"description\": \"Aide à la logistique du parcours\",\n    \"taskDate\": \"2026-03-15\",\n    \"startTime\": \"13:00:00\",\n    \"endTime\": \"17:00:00\",\n    \"location\": \"Site B\",\n    \"taskType\": \"SUPPORT_LOGISTIQUE\",\n    \"requiredLanguages\": []\n  }\n]"
        },
        "url": {
          "raw": "{{volunteer_base}}/api/v1/admin/volunteers/tasks/import",
          "host": [
            "{{volunteer_base}}"
          ],
          "path": [
            "api",
            "v1",
            "admin",
            "volunteers",
            "tasks",
            "import"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status is 201\", function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "const data = pm.response.json();",
              "pm.test(\"Response is an array\", function () {",
              "  pm.expect(Array.isArray(data)).to.eql(true);",
              "});",
              "",
              "pm.test(\"At least one imported task is returned\", function () {",
              "  pm.expect(data.length).to.be.above(0);",
              "});",
              "",
              "if (data.length > 0) {",
              "  pm.environment.set('task_id', data[0].id);",
              "  pm.test(\"Each task has required fields\", function () {",
              "    const task = data[0];",
              "    pm.expect(task.title).to.exist;",
              "    pm.expect(task.taskDate).to.exist;",
              "    pm.expect(task.location).to.exist;",
              "  });",
              "}"
            ]
          }
        }
      ],
      "response": []
