                                    "});",
                                    "pm.test(\"Tous en statut EN_ATTENTE\", () => {",
                                    "    const json = pm.response.json();",
                                    "    json.forEach(r => pm.expect(r.statut).to.eql('EN_ATTENTE'));",
                                    "});",
