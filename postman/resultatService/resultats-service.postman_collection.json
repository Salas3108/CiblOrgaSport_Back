                                    "    const json = pm.response.json();",
                                    "    const premier = json.find(r => r.classement === 1);",
                                    "    pm.expect(premier).to.not.be.undefined;",
                                    "    console.log('1er :', premier.athleteId, '— temps :', premier.valeurPrincipale);",
                                    "});",
                                    "if (pm.response.json().length > 0) {",
                                    "    pm.collectionVariables.set('resultat_id', pm.response.json()[0].id);",
                                    "}"
