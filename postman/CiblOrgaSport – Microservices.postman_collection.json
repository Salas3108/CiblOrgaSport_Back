									"    }",
									"    ",
									"    // Ensure response is an object",
									"    pm.expect(jsonData).to.be.an('object', \"Response should be an object\");",
									"    ",
									"    // Check that 'id' property exists",
									"    pm.expect(jsonData).to.have.property('id', \"Response should have an 'id' property\");",
									"    ",
									"    // Ensure id is not null or undefined",
									"    pm.expect(jsonData.id).to.not.be.null;",
									"    pm.expect(jsonData.id).to.not.be.undefined;",
									"    ",
									"    // Validate id is of expected type (string or number)",
									"    pm.expect(jsonData.id).to.satisfy(",
									"        (id) => typeof id === 'string' || typeof id === 'number',",
									"        \"id should be a string or number\"",
									"    );",
									"    ",
									"    // If id is a string, ensure it's not empty",
									"    if (typeof jsonData.id === 'string') {",
									"        pm.expect(jsonData.id.trim()).to.not.be.empty;",
									"    }",
