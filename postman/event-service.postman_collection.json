        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Championnat Régional\",\n  \"location\": \"Paris\",\n  \"date\": \"2026-03-15\"\n}"
        },
        "url": {
          "raw": "http://localhost:8084/events",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8084",
          "path": ["events"]
        }
      }
    },
    {
