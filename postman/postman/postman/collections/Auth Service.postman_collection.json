{
  "info": {
    "_postman_id": "bf307db5-3b36-4120-9d84-d603276a7f87",
    "name": "Auth Service",
    "description": "Register, Login, and Me requests for Auth Service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Register",
      "id": "300d564f-afd9-4373-a09a-d7ad75e4549c",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"john.doe\",\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"Secret123!\",\n  \"role\": \"ATHLETE\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "if (json && json.token) {",
              "  pm.collectionVariables.set('token', json.token);",
              "  pm.collectionVariables.set('username', json.username || 'john.doe');",
              "  pm.collectionVariables.set('role', json.role || 'ROLE_ATHLETE');",
              "}"
            ],
            "type": "text/javascript",
            "id": "0f429a54-c709-487e-870f-690ab2e37d22"
          }
        }
      ],
      "id": "f8e642f6-14b5-4d60-8e4c-a49ff739c68e",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"john.doe\",\n  \"password\": \"Secret123!\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Me",
      "id": "416ba7cb-2a47-4ded-a82d-9da47ae5837a",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/me",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "me"
          ]
        }
      },
      "response": []
    }
  ],
  "variable": [
