            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Champ nonLues présent\", () => {",
                  "    const data = pm.response.json();",
                  "    pm.expect(data).to.have.property('nonLues');",
                  "    pm.expect(data.nonLues).to.be.a('number');",
                  "});"
                ],
                "id": "0c9838f4-7f12-4164-9863-597529fb2ec3"
              }
            }
          ],
