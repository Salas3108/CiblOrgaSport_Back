{
  "info": {
    "_postman_id": "5a148016-9bbd-4f2e-822d-bbb394fdb41b",
    "name": "Notifications Service - CiblOrgaSport Copy",
    "description": "Endpoints REST du notifications-service (port 8089). Les notifications sont créées automatiquement via Kafka quand un incident est publié. Le push temps réel se fait en WebSocket STOMP sur ws://localhost:8089/ws → topic /topic/notifications/{spectateurId}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Historique",
      "item": [
        {
          "name": "Toutes les notifications d'un spectateur",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Réponse est un tableau\", () => {",
                  "    const data = pm.response.json();",
                  "    pm.expect(data).to.be.an('array');",
                  "});",
                  "const data = pm.response.json();",
                  "if (data.length > 0) {",
                  "    pm.environment.set('notification_id', data[0].id);",
                  "    pm.collectionVariables.set('notification_id', data[0].id);",
                  "}"
                ],
                "id": "5a906a0c-6303-4b03-912d-215f13c235fd"
              }
            }
          ],
          "id": "7a9f08d1-aeb3-4b37-b826-612088750e97",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{notif_base}}/api/notifications/spectateur/{{spectateur_id}}",
              "host": [
                "{{notif_base}}"
              ],
              "path": [
                "api",
                "notifications",
                "spectateur",
                "{{spectateur_id}}"
              ]
            },
            "description": "Retourne toutes les notifications du spectateur triées par date décroissante."
          },
          "response": []
        },
        {
          "name": "Notifications non lues",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Toutes les entrées sont non lues\", () => {",
                  "    const data = pm.response.json();",
                  "    data.forEach(n => pm.expect(n.lu).to.equal(false));",
                  "});"
                ],
                "id": "4934f92d-0a01-4b4a-a390-90b70e9ec7d7"
              }
            }
          ],
          "id": "a1153289-4812-4b64-9c93-8a0d9c5f70d3",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{notif_base}}/api/notifications/spectateur/{{spectateur_id}}/non-lues",
              "host": [
                "{{notif_base}}"
              ],
              "path": [
                "api",
                "notifications",
                "spectateur",
                "{{spectateur_id}}",
                "non-lues"
              ]
            },
            "description": "Retourne uniquement les notifications avec lu=false."
          },
          "response": []
