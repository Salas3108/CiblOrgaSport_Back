                  "  pm.test('Response has id', function(){ pm.expect(json).to.have.property('id'); });",
                  "  if (json && json.id) pm.environment.set('epreuve_id', json.id);",
                  "  var compResp = json.competitionId || (json.competition && json.competition.id);",
                  "  var compEnv = String(pm.environment.get('competition_id') || '');",
                  "  if (compEnv) pm.test('competitionId matches', function(){ pm.expect(String(compResp)).to.equal(compEnv); });",
                  "} catch(e) {}"
                ],
                "type": "text/javascript"
              }
            }
          ]
