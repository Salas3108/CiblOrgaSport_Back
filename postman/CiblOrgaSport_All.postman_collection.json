    {
      "name": "auth-service",
      "item": [
        {
          "name": "Register (commissaire)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"username\": \"commissaire1\", \"email\": \"comm@example.com\", \"password\": \"commiss123\", \"role\": \"COMMISSAIRE\" }" },
            "url": { "raw": "{{auth_base}}/auth/register", "host": ["{{auth_base}}"], "path": ["auth","register"] }
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test(\"Status code is 201 or 200\", function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });"], "type": "text/javascript" } }]
        },
        {
          "name": "Login - commissaire",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"username\": \"commissaire1\", \"password\": \"commiss123\" }" },
            "url": { "raw": "{{auth_base}}/auth/login", "host": ["{{auth_base}}"], "path": ["auth","login"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
            "try { var json = pm.response.json(); if (json && json.token) { pm.environment.set('token', json.token); pm.environment.set('jwt', 'Bearer ' + json.token); } } catch(e) {}"
          ], "type": "text/javascript" } }]
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "{{jwt}}" }],
            "url": { "raw": "{{auth_base}}/auth/me", "host": ["{{auth_base}}"], "path": ["auth","me"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test(\"Status 200\", function(){ pm.response.to.have.status(200); });",
            "try { var json = pm.response.json(); pm.test('has username/email', function(){ pm.expect(json).to.have.property('username'); pm.expect(json).to.have.property('email'); }); } catch(e) {}"
          ], "type": "text/javascript" } }]
        }
      ]
    },
