{
  "info": {
    "name": "Auth Service",
    "_postman_id": "c7b8e6db-1234-4a6a-9f01-abcdef123456",
    "description": "DEPRECATED - tests consolidated into 'CiblOrgaSport - Unified Tests' (see postman/CiblOrgaSport_All.postman_collection.json)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "DEPRECATED - See Unified collection",
      "request": {
        "method": "GET",
        "url": { "raw": "https://example.com/deprecated-auth-collection", "host": ["example.com"], "path": ["deprecated-auth-collection"] }
      }
    },
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"john.doe\",\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"Secret123!\",\n  \"role\": \"ATHLETE\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201 or 200\", function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
              "try { var json = pm.response.json(); pm.test('Response has username', function() { pm.expect(json).to.have.property('username'); }); } catch (e) {}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"john.doe\",\n  \"password\": \"Secret123!\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "if (json && json.token) {",
              "  pm.collectionVariables.set('token', json.token);",
              "  pm.collectionVariables.set('username', json.username || 'john.doe');",
              "  pm.collectionVariables.set('role', json.role || 'ROLE_ATHLETE');",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Me",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
              "try { var json = pm.response.json(); pm.test('Has username/email', function(){ pm.expect(json).to.have.property('username'); pm.expect(json).to.have.property('email'); }); } catch (e) {}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" }
  ]
}
