# .env.prod.example — Template de production pour OVH
# Copier ce fichier en .env.prod et remplir toutes les valeurs <VALEUR_À_DÉFINIR>
# IMPORTANT: Ne jamais commiter .env.prod dans git !

# ─── VMs OVH (renseigner après provisionnement) ────────────────────────────────
# IP privée vRack de vm-database
DB_HOST=<IP_PRIVEE_VM_DATABASE>

# ─── Base de données ───────────────────────────────────────────────────────────
POSTGRES_DB=glop
POSTGRES_USER=admin
POSTGRES_PASSWORD=<VALEUR_À_DÉFINIR>

# ─── JWT (générer avec: openssl rand -hex 64) ──────────────────────────────────
JWT_SECRET=<VALEUR_À_DÉFINIR>

# ─── Docker Hub ────────────────────────────────────────────────────────────────
DOCKERHUB_USERNAME=<VALEUR_À_DÉFINIR>

# ─── Kafka ─────────────────────────────────────────────────────────────────────
# Kafka Cluster ID — générer avec: docker run --rm confluentinc/cp-kafka:7.7.0 kafka-storage random-uuid
KAFKA_CLUSTER_ID=<VALEUR_À_DÉFINIR>

# ─── Spring ────────────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod
